<template>
  <div class="admin-container">
    <!-- Header -->
    <header class="admin-header">
      <div class="header-content">
        <div class="logo-section">
          <NuxtLink to="/dashboard" class="back-button">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M19 12H5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12 19L5 12L12 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Zurück
          </NuxtLink>
          <h1>⚙️ Admin Panel</h1>
        </div>
        
        <button @click="handleLogout" class="logout-button">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 21H5C4.46957 21 3.96086 20.7893 3.58579 20.4142C3.21071 20.0391 3 19.5304 3 19V5C3 4.46957 3.21071 3.96086 3.58579 3.58579C3.96086 3.21071 4.46957 3 5 3H9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M16 17L21 12L16 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M21 12H9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Abmelden
        </button>
      </div>
    </header>

    <!-- Main Content -->
    <main class="admin-main">
      <div v-if="!isAdmin && !loading" class="access-denied">
        <div class="denied-icon">🚫</div>
        <h2>Zugriff verweigert</h2>
        <p>Du hast keine Admin-Rechte.</p>
        <NuxtLink to="/dashboard" class="btn-primary">Zurück zum Dashboard</NuxtLink>
      </div>

      <div v-else-if="loading" class="loading-state">
        <div class="spinner-big"></div>
        <p>Lade Admin-Panel...</p>
      </div>

      <div v-else>
        <div class="welcome-section">
          <h2>Admin Panel 👨‍💼</h2>
          <p class="welcome-subtitle">Stempel Tobias ein - Dienstag & Donnerstag</p>
        </div>

        <!-- Current Day Info -->
        <div class="day-info" :class="dayClass">
          <div class="day-icon">{{ dayIcon }}</div>
          <div class="day-content">
            <h3>{{ currentDayName }}</h3>
            <p>{{ dayMessage }}</p>
          </div>
        </div>

        <!-- Stamp In Form -->
        <div class="stamp-form-card">
          <h3 class="form-title">🎯 Tobias einstempeln</h3>
          
          <form @submit.prevent="handleStampIn" class="stamp-form">
            <div class="form-group">
              <label>Status</label>
              <div class="radio-group">
                <label class="radio-label" :class="{ active: stampStatus === 'on-time' }">
                  <input type="radio" v-model="stampStatus" value="on-time" />
                  <span class="radio-custom on-time">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M22 11.08V12C21.9988 14.1564 21.3005 16.2547 20.0093 17.9818C18.7182 19.709 16.9033 20.9725 14.8354 21.5839C12.7674 22.1953 10.5573 22.1219 8.53447 21.3746C6.51168 20.6273 4.78465 19.2461 3.61096 17.4371C2.43727 15.628 1.87979 13.4881 2.02168 11.3363C2.16356 9.18455 2.99721 7.13631 4.39828 5.49706C5.79935 3.85781 7.69279 2.71537 9.79619 2.24013C11.8996 1.7649 14.1003 1.98232 16.07 2.85999" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M22 4L12 14.01L9 11.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Pünktlich ✅
                  </span>
                </label>
                
                <label class="radio-label" :class="{ active: stampStatus === 'late' }">
                  <input type="radio" v-model="stampStatus" value="late" />
                  <span class="radio-custom late">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                      <path d="M12 6V12L16 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Zu spät ⏰
                  </span>
                </label>
              </div>
            </div>

            <div v-if="stampStatus === 'late'" class="form-group">
              <label for="minutes">Minuten zu spät</label>
              <input 
                id="minutes"
                v-model.number="minutesLate" 
                type="number" 
                min="1" 
                required 
                placeholder="z.B. 15"
              />
            </div>

            <div class="form-group">
              <label for="note">Notiz (optional)</label>
              <textarea 
                id="note"
                v-model="note" 
                rows="3" 
                placeholder="z.B. Alarm nicht gehört, Bahn verpasst..."
              ></textarea>
            </div>

            <div v-if="error" class="error-message">
              {{ error }}
            </div>

            <div v-if="success" class="success-message">
              ✅ {{ success }}
            </div>

            <button type="submit" class="btn-submit" :disabled="submitting">
              <span v-if="!submitting">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M9 11L12 14L22 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M21 12V19C21 19.5304 20.7893 20.0391 20.4142 20.4142C20.0391 20.7893 19.5304 21 19 21H5C4.46957 21 3.96086 20.7893 3.58579 20.4142C3.21071 20.0391 3 19.5304 3 19V5C3 4.46957 3.21071 3.96086 3.58579 3.58579C3.96086 3.21071 4.46957 3 5 3H16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Einstempeln
              </span>
              <span v-else class="loading-spinner">
                <div class="spinner"></div>
                Speichere...
              </span>
            </button>
          </form>
        </div>

        <!-- Today's Stamps -->
        <div class="today-stamps">
          <h3 class="section-title">📋 Einträge diese Woche</h3>
          <div v-if="weekStamps.length === 0" class="empty-state">
            <p>Noch keine Einträge diese Woche.</p>
          </div>
          <div v-else class="stamps-list">
            <div 
              v-for="stamp in weekStamps" 
              :key="stamp.id"
              class="stamp-item"
              :class="stamp.status"
            >
              <div class="stamp-icon">
                <span v-if="stamp.status === 'on-time'">✅</span>
                <span v-else>⏰</span>
              </div>
              <div class="stamp-content">
                <div class="stamp-main">
                  <strong>{{ stamp.dayOfWeek }}, {{ formatDate(stamp.date) }}</strong>
                  <span v-if="stamp.status === 'on-time'" class="status-badge on-time">Pünktlich</span>
                  <span v-else class="status-badge late">{{ stamp.minutesLate }} Min zu spät</span>
                </div>
                <p v-if="stamp.note" class="stamp-note">{{ stamp.note }}</p>
                <p class="stamp-time">{{ formatTime(stamp.timestamp) }}</p>
              </div>
              <button 
                @click="handleDeleteStamp(stamp.id)" 
                class="delete-button"
                :disabled="deleting"
              >
                🗑️
              </button>
            </div>
          </div>
        </div>

        <!-- Admin Tools -->
        <div class="admin-tools">
          <h3 class="section-title">⚙️ Admin-Werkzeuge</h3>
          
          <div class="tools-grid">
            <!-- Reset Streak -->
            <div class="tool-card danger">
              <div class="tool-header">
                <h4>🔄 Streak zurücksetzen</h4>
                <p>Setzt den aktuellen Streak auf 0</p>
              </div>
              <div class="tool-content">
                <textarea 
                  v-model="resetReason" 
                  rows="2" 
                  placeholder="Grund für Reset (optional)..."
                  class="tool-input"
                ></textarea>
                <button 
                  @click="handleResetStreak" 
                  class="btn-danger"
                  :disabled="resetting"
                >
                  {{ resetting ? 'Wird zurückgesetzt...' : 'Streak zurücksetzen' }}
                </button>
              </div>
            </div>

            <!-- View User Stats -->
            <div class="tool-card info">
              <div class="tool-header">
                <h4>📊 Benutzer-Statistiken</h4>
                <p>Aktuelle Stats von Tobias</p>
              </div>
              <div class="tool-content stats-display">
                <div class="stat-row">
                  <span>Aktueller Streak:</span>
                  <strong>{{ userStats.currentStreak || 0 }}x</strong>
                </div>
                <div class="stat-row">
                  <span>Pünktlich:</span>
                  <strong>{{ userStats.onTimeCount || 0 }}x</strong>
                </div>
                <div class="stat-row">
                  <span>Zu spät:</span>
                  <strong>{{ userStats.lateCount || 0 }}x</strong>
                </div>
                <div class="stat-row">
                  <span>Beste Serie:</span>
                  <strong>{{ userStats.longestStreak || 0 }}x</strong>
                </div>
                <button @click="refreshStats" class="btn-secondary">
                  🔄 Aktualisieren
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</template>

<script lang="ts" setup>
definePageMeta({
  middleware: 'auth'
})

const { user, logout } = useFirebaseAuth()
const { 
  stampIn, 
  getThisWeekStamps, 
  isUserAdmin, 
  resetStreak, 
  deleteStamp,
  getUserStats 
} = useStempelCard()
const router = useRouter()

const loading = ref(true)
const isAdmin = ref(false)
const stampStatus = ref<'on-time' | 'late'>('on-time')
const minutesLate = ref(0)
const note = ref('')
const submitting = ref(false)
const error = ref('')
const success = ref('')
const weekStamps = ref<any[]>([])
const userStats = ref<any>({})
const resetReason = ref('')
const resetting = ref(false)
const deleting = ref(false)

const currentDate = new Date()
const currentDay = currentDate.getDay() // 0 = Sunday, 2 = Tuesday, 4 = Thursday

const currentDayName = computed(() => {
  return currentDate.toLocaleDateString('de-DE', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' })
})

const dayClass = computed(() => {
  if (currentDay === 2 || currentDay === 4) return 'stamp-day'
  return 'no-stamp-day'
})

const dayIcon = computed(() => {
  if (currentDay === 2 || currentDay === 4) return '📅'
  return '📆'
})

const dayMessage = computed(() => {
  if (currentDay === 2) return 'Heute ist Dienstag - Stempel-Tag!'
  if (currentDay === 4) return 'Heute ist Donnerstag - Stempel-Tag!'
  return 'Heute ist kein Stempel-Tag (nur Dienstag & Donnerstag)'
})

const loadWeekStamps = async () => {
  try {
    const stamps = await getThisWeekStamps('tobias')
    weekStamps.value = stamps
  } catch (err) {
    console.error('Error loading week stamps:', err)
  }
}

const handleStampIn = async () => {
  error.value = ''
  success.value = ''
  submitting.value = true

  try {
    const minutes = stampStatus.value === 'late' ? minutesLate.value : 0
    
    await stampIn('tobias', stampStatus.value, minutes, note.value)
    
    success.value = stampStatus.value === 'on-time' 
      ? '🎉 Tobias wurde als pünktlich eingestempelt!' 
      : `⏰ Tobias wurde mit ${minutes} Minuten Verspätung eingestempelt.`
    
    // Reset form
    stampStatus.value = 'on-time'
    minutesLate.value = 0
    note.value = ''
    
    // Reload stamps
    await loadWeekStamps()
    
    // Clear success message after 5 seconds
    setTimeout(() => {
      success.value = ''
    }, 5000)
  } catch (err: any) {
    error.value = 'Fehler beim Einstempeln: ' + err.message
  } finally {
    submitting.value = false
  }
}

const handleLogout = async () => {
  await logout()
  router.push('/login')
}

const formatDate = (dateString: string) => {
  const date = new Date(dateString)
  return date.toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' })
}

const formatTime = (timestamp: any) => {
  const date = timestamp.toDate()
  return date.toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' })
}

const handleResetStreak = async () => {
  if (!confirm('Bist du sicher, dass du den Streak zurücksetzen möchtest?')) {
    return
  }

  resetting.value = true
  error.value = ''
  success.value = ''

  try {
    if (!user.value?.email) throw new Error('Nicht eingeloggt')
    
    const reason = resetReason.value || 'Kein Grund angegeben'
    await resetStreak('tobias', user.value.email, reason)
    
    success.value = '✅ Streak wurde erfolgreich zurückgesetzt!'
    resetReason.value = ''
    
    // Refresh stats
    await refreshStats()
    
    setTimeout(() => {
      success.value = ''
    }, 5000)
  } catch (err: any) {
    error.value = 'Fehler beim Zurücksetzen: ' + err.message
  } finally {
    resetting.value = false
  }
}

const handleDeleteStamp = async (stampId: string) => {
  if (!confirm('Bist du sicher, dass du diesen Eintrag löschen möchtest?')) {
    return
  }

  deleting.value = true
  error.value = ''
  success.value = ''

  try {
    if (!user.value?.email) throw new Error('Nicht eingeloggt')
    
    await deleteStamp(stampId, 'tobias', user.value.email)
    
    success.value = '✅ Eintrag wurde gelöscht!'
    
    // Reload stamps
    await loadWeekStamps()
    await refreshStats()
    
    setTimeout(() => {
      success.value = ''
    }, 3000)
  } catch (err: any) {
    error.value = 'Fehler beim Löschen: ' + err.message
  } finally {
    deleting.value = false
  }
}

const refreshStats = async () => {
  try {
    const stats = await getUserStats('tobias')
    userStats.value = stats
  } catch (err) {
    console.error('Error refreshing stats:', err)
  }
}

// Load stats on mount
onMounted(async () => {
  try {
    if (user.value?.email) {
      isAdmin.value = await isUserAdmin(user.value.email)
    }

    if (isAdmin.value) {
      await loadWeekStamps()
      await refreshStats()
    }
  } catch (err) {
    console.error('Error loading admin panel:', err)
  } finally {
    loading.value = false
  }
})
</script>

