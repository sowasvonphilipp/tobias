<script lang="ts" setup>
definePageMeta({
  middleware: 'auth'
})

const { user, logout } = useFirebaseAuth()
const { getUserStats, getRecentStamps, getAuditLogs, isUserAdmin } = useStempelCard()
const router = useRouter()

const userInitial = computed(() => {
  return user.value?.email?.charAt(0).toUpperCase() || 'T'
})

const loading = ref(true)
const isAdmin = ref(false)
const stats = ref({
  totalStamps: 0,
  onTimeCount: 0,
  lateCount: 0,
  currentStreak: 0,
  longestStreak: 0,
  totalMinutesLate: 0,
  averageMinutesLate: 0,
  rewardsEarned: [],
  nextRewardProgress: 0
})
const recentStamps = ref<any[]>([])
const auditLogs = ref<any[]>([])

onMounted(async () => {
  try {
    // Check if user is admin
    if (user.value?.email) {
      isAdmin.value = await isUserAdmin(user.value.email)
    }

    // Load user stats
    const userId = user.value?.uid || 'tobias'
    const userStats: any = await getUserStats(userId)
    stats.value = userStats

    // Load recent stamps
    const stamps = await getRecentStamps(userId, 10)
    recentStamps.value = stamps

    // Load audit logs
    const logs = await getAuditLogs(userId, 10)
    auditLogs.value = logs
  } catch (error) {
    console.error('Error loading dashboard data:', error)
  } finally {
    loading.value = false
  }
})

const handleLogout = async () => {
  await logout()
  router.push('/login')
}

const formatDate = (dateString: string) => {
  const date = new Date(dateString)
  return date.toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' })
}

const getStreakMessage = () => {
  const streak = stats.value.currentStreak
  if (streak === 0) return 'Zeit für einen Neustart! 💪'
  if (streak >= 30) return 'ABSOLUT LEGENDÄR! 👑🔥'
  if (streak >= 20) return 'DU BIST UNAUFHALTBAR! 🚀'
  if (streak >= 12) return 'Phänomenal! Weiter so! ⭐'
  if (streak >= 8) return 'Fantastisch! Keep it up! 🎉'
  if (streak >= 5) return 'Super Leistung! 💯'
  if (streak >= 3) return 'Guter Start! 🔥'
  return 'Jetzt durchziehen! 💪'
}

const formatAuditTime = (timestamp: any) => {
  if (!timestamp) return ''
  const date = timestamp.toDate ? timestamp.toDate() : new Date(timestamp)
  const now = new Date()
  const diffMs = now.getTime() - date.getTime()
  const diffMins = Math.floor(diffMs / 60000)
  const diffHours = Math.floor(diffMs / 3600000)
  const diffDays = Math.floor(diffMs / 86400000)
  
  if (diffMins < 1) return 'Gerade eben'
  if (diffMins < 60) return `vor ${diffMins} Min`
  if (diffHours < 24) return `vor ${diffHours} Std`
  if (diffDays < 7) return `vor ${diffDays} Tag${diffDays > 1 ? 'en' : ''}`
  return date.toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' })
}
</script>

